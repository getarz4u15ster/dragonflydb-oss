        <mxCell id="requirements-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFCC;strokeColor=#d6b656;align=center;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;fontColor=#0B0B0B;arcSize=50;" value="&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Technical Requirements&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(11, 11, 11); font-size: 12px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;background-color: transparent;&quot;&gt;Schema&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;: symbol, price, quantity, timestamp (ISO8601), trade_id — Producer + Bridge store full JSON.&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font color=&quot;#0b0b0b&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(11, 11, 11); font-size: 12px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;background-color: transparent;&quot;&gt;Ingestion&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;: ~50k eps (events-per-second), spikes to 500k; no backpressure to Kafka — Pull-based consumer; scale bridge + partitions for production.&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font color=&quot;#0b0b0b&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(11, 11, 11); font-size: 12px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;background-color: transparent;&quot;&gt;Symbol Scale&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;: 12k symbols, 500–1k when hot — One LIST per symbol (trades:SYMBOL); scales to 12k+ keys.&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(11, 11, 11); font-size: 12px; background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;color: rgb(11, 11, 11); font-size: 12px; background-color: transparent;&quot;&gt;Retention&lt;/b&gt;&lt;span style=&quot;color: rgb(11, 11, 11); font-size: 12px; background-color: transparent;&quot;&gt;: last 10 trades per symbol only — LPUSH + LTRIM 0 9 (see Bridge → Dragonfly).&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font color=&quot;#0b0b0b&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(11, 11, 11); font-size: 12px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;background-color: transparent;&quot;&gt;Frontend Query&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;: REST API → data store; &amp;lt;1 ms from store — Query API uses LRANGE 0 9; benchmark shows sub-ms latency.&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;font color=&quot;#0b0b0b&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(11, 11, 11); font-size: 12px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;background-color: transparent;&quot;&gt;Client: &lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Redis-compatible&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;; &amp;lt;1 ms target — Use official Redis client (redis-py); Dragonfly-compatible.&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="310" width="1030" x="100" y="700" as="geometry" />
        </mxCell>
        <mxCell id="business-outcomes" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CC99FF;strokeColor=#82b366;align=center;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;fontColor=#0B0B0B;arcSize=50;" value="&lt;h2 data-section-id=&quot;kafsje&quot; data-start=&quot;113&quot; data-end=&quot;143&quot;&gt;&lt;font style=&quot;color: rgb(11, 11, 11);&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;font style=&quot;font-size: 26px;&quot;&gt;Business Value and Outcomes&lt;/font&gt;&lt;/font&gt;&lt;/h2&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(11, 11, 11);&quot;&gt;&lt;font style=&quot;font-size: 26px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;h2 data-section-id=&quot;kafsje&quot; data-start=&quot;113&quot; data-end=&quot;143&quot; style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;strong data-start=&quot;145&quot; data-end=&quot;170&quot; style=&quot;color: rgb(11, 11, 11); background-color: transparent;&quot;&gt;Lower Compute Costs -&amp;nbsp;&lt;/strong&gt;&lt;span style=&quot;color: rgb(11, 11, 11); background-color: transparent; font-weight: normal; text-align: center;&quot;&gt;Higher throughput per node means fewer machines required to handle the same workload.&lt;/span&gt;&lt;/font&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;kafsje&quot; data-start=&quot;113&quot; data-end=&quot;143&quot; style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;strong data-start=&quot;398&quot; data-end=&quot;430&quot; style=&quot;color: rgb(11, 11, 11); background-color: transparent; text-align: center;&quot;&gt;Reduced Operational Burden -&amp;nbsp;&lt;/strong&gt;&lt;span style=&quot;color: rgb(11, 11, 11); background-color: transparent; font-weight: normal; text-align: center;&quot;&gt;Fewer nodes and a simpler topology reduce scaling complexity, monitoring overhead, and failure domains.&lt;/span&gt;&lt;/font&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;kafsje&quot; data-start=&quot;113&quot; data-end=&quot;143&quot; style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;strong data-start=&quot;538&quot; data-end=&quot;564&quot; style=&quot;color: rgb(11, 11, 11); background-color: transparent; text-align: center;&quot;&gt;Simple Architecture -&amp;nbsp;&lt;/strong&gt;&lt;span style=&quot;color: rgb(11, 11, 11); background-color: transparent; font-weight: normal; text-align: center;&quot;&gt;A single in-memory store replaces multi-tier cache + database designs for hot data workloads.&lt;/span&gt;&lt;/font&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;kafsje&quot; data-start=&quot;113&quot; data-end=&quot;143&quot; style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;strong data-start=&quot;794&quot; data-end=&quot;815&quot; style=&quot;color: rgb(11, 11, 11); background-color: transparent; text-align: center;&quot;&gt;Rapid adoption -&amp;nbsp;&lt;/strong&gt;&lt;span style=&quot;color: rgb(11, 11, 11); background-color: transparent; font-weight: normal; text-align: center;&quot;&gt;Drop-in Redis compatibility means existing clients and tooling work with no application changes.&lt;/span&gt;&lt;/font&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;kafsje&quot; data-start=&quot;113&quot; data-end=&quot;143&quot; style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;strong data-start=&quot;916&quot; data-end=&quot;944&quot; style=&quot;color: rgb(11, 11, 11); background-color: transparent; text-align: center;&quot;&gt;Lower Operational Risk -&amp;nbsp;&lt;/strong&gt;&lt;span style=&quot;color: rgb(11, 11, 11); background-color: transparent; font-weight: normal; text-align: center;&quot;&gt;Fewer components and simpler data flows reduce system fragility and operational incidents.&lt;/span&gt;&lt;/font&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;kafsje&quot; data-start=&quot;113&quot; data-end=&quot;143&quot; style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/h2&gt;" vertex="1">
          <mxGeometry height="310" width="1010" x="1150" y="690" as="geometry" />
        </mxCell>
